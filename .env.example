# ============================================================================
# Prompt-To-App Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.

# ── Required (at least one AI provider) ───────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/promptios

# AI providers — configure at least one. Multiple providers enable fallback
# and user choice. The first configured provider becomes the default.

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Google Gemini (https://aistudio.google.com/apikey)
# GEMINI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/settings/keys)
# ANTHROPIC_API_KEY=

# ── Optional ─────────────────────────────────────────────────────────────────

# Override OpenAI base URL (for proxies or compatible APIs)
# OPENAI_BASE_URL=https://api.openai.com/v1

# API server port (default: 8080)
# PORT=8080

# Frontend dev server port (default: 5173)
# VITE_PORT=5173

# Session secret for cookie signing (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-string

# Allowed CORS origins (comma-separated). All origins allowed in development.
# In production, set to your frontend domain(s).
# ALLOWED_ORIGINS=https://app.example.com,https://www.example.com

# ── Stripe Billing (optional — required for paid plans) ──────────────────────

# Stripe API key (https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (https://dashboard.stripe.com/webhooks)
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_STUDIO_PRICE_ID=price_...

# ── Observability (optional) ──────────────────────────────────────────────

# Sentry DSN for error tracking (https://sentry.io)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry performance sampling rates (0.0 – 1.0, default 0.1)
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Git commit SHA — set by CI for release tracking
# RELEASE_SHA=abc1234

# Log level (default: info). Options: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info
